                    <li><a href="#projects">Kunj Bihari Commercial</a></li>
                    <li><a href="#projects">ATS Kabana High</a></li>
                    <li><a href="#projects">ATS Homekraft</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Newsletter</h4>
