                <div class="newsletter">
                    <input type="email" placeholder="Your email">
                    <button><i class="fas fa-arrow-right"></i></button>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Aaryan Anuj Enterprises. All rights reserved.</p>
