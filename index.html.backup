    <section id="about" class="about">
        <div class="about-container">
            <div class="about-image">
                <img src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=600&h=700&fit=crop" alt="About Us">
                <div class="about-badge">
                    <i class="fas fa-trophy"></i>
                    <span>Award Winning</span>
                </div>
            </div>
            <div class="about-content">
                <span class="section-subtitle">About Us</span>
                <h2>Building Dreams, Creating Landmarks</h2>
                <p>Aaryan Anuj Enterprises is a distinguished name in the real estate industry, committed to delivering exceptional residential and commercial properties. With over 10 years of expertise, we have established ourselves as a trusted partner for those seeking quality, innovation, and value.</p>
                <p>Our portfolio showcases a perfect blend of modern architecture, strategic locations, and world-class amenities. We believe in creating spaces that not only meet but exceed expectations, transforming the way people live and work.</p>
                <div class="about-values">
                    <div class="value-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Quality Construction</span>
                    </div>
                    <div class="value-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Timely Delivery</span>
                    </div>
                    <div class="value-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Customer Satisfaction</span>
                    </div>
                    <div class="value-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Transparent Dealings</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="owner-section">
        <div class="owner-container">
            <div class="owner-content">
                <span class="section-subtitle">Leadership</span>
                <h2>Meet Our Founder</h2>
                <div class="owner-card">
                    <div class="owner-image">
                        <img src="image.jpg.jpeg" alt="Anuj Singh">
                        <div class="owner-badge">
                            <i class="fas fa-star"></i>
                        </div>
                    </div>
                    <div class="owner-info">
                        <h3>Anuj Singh</h3>
                        <p class="owner-title">Founder & CEO</p>
                        <p class="owner-bio">With over 10 years of dedicated experience in the real estate industry, Anuj Singh has been the driving force behind Aaryan Anuj Enterprises' success. His vision of creating quality living spaces combined with unwavering commitment to customer satisfaction has transformed the company into a trusted name in real estate.</p>
                        <p class="owner-bio">Under his leadership, the company has successfully delivered 30+ premium projects, earning the trust of over 150 satisfied clients. His expertise spans across residential and commercial developments, with a keen eye for strategic locations and innovative design.</p>
                        <p class="owner-bio">Anuj believes in building not just properties, but lasting relationships. His hands-on approach ensures that every project reflects the highest standards of quality, transparency, and timely delivery. His dedication to excellence and ethical business practices has made Aaryan Anuj Enterprises a preferred choice for homebuyers and investors alike.</p>
                        <div class="owner-highlights">
                            <div class="highlight-item">
                                <i class="fas fa-briefcase"></i>
                                <div>
                                    <h4>10+ Years</h4>
                                    <p>Industry Experience</p>
                                </div>
                            </div>
                            <div class="highlight-item">
                                <i class="fas fa-certificate"></i>
                                <div>
                                    <h4>30+ Projects</h4>
                                    <p>Successfully Delivered</p>
                                </div>
                            </div>
                            <div class="highlight-item">
                                <i class="fas fa-users"></i>
                                <div>
                                    <h4>150+ Clients</h4>
                                    <p>Satisfied Customers</p>
                                </div>
                            </div>
                        </div>
                        <blockquote class="owner-quote">
                            <i class="fas fa-quote-left"></i>
                            <p>"Our mission is simple - to create spaces where dreams come home. Every project we undertake is a commitment to quality, integrity, and the trust our clients place in us."</p>
                            <cite>- Anuj Singh</cite>
                        </blockquote>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="services" class="services">
        <div class="section-header">
            <span class="section-subtitle">What We Offer</span>
            <h2>Our Services</h2>
        </div>
        <div class="services-grid">
            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-home"></i>
                </div>
                <h3>Property Sales</h3>
                <p>Find your dream property from our extensive portfolio of residential and commercial spaces</p>
            </div>
            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-key"></i>
                </div>
                <h3>Property Rental</h3>
                <p>Premium rental solutions for both short-term and long-term requirements</p>
            </div>
            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-chart-line"></i>
                </div>
                <h3>Investment Advisory</h3>
                <p>Expert guidance on real estate investments for maximum returns</p>
            </div>
            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-file-contract"></i>
                </div>
                <h3>Legal Assistance</h3>
                <p>Complete documentation and legal support for hassle-free transactions</p>
            </div>
        </div>
    </section>

    <section id="contact" class="contact">
        <div class="contact-container">
            <div class="contact-info">
                <span class="section-subtitle">Get In Touch</span>
                <h2>Let's Discuss Your Dream Property</h2>
                <p>Our team is ready to assist you in finding the perfect space that matches your requirements and budget.</p>
                
                <div class="contact-details">
                    <div class="contact-item">
                        <i class="fas fa-phone"></i>
                        <div>
                            <h4>Phone</h4>
                            <p>+91 7979012267</p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <i class="fas fa-envelope"></i>
                        <div>
                            <h4>Email</h4>
                            <p>xaaryananuj@gmail.com</p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <i class="fas fa-map-marker-alt"></i>
                        <div>
                            <h4>Office</h4>
                            <p>Business District, India</p>
                        </div>
                    </div>
                </div>

                <div class="social-links">
                    <a href="#"><i class="fab fa-facebook"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-linkedin"></i></a>
                    <a href="#"><i class="fab fa-twitter"></i></a>
                </div>
            </div>

            <form class="contact-form" action="https://formsubmit.co/xaaryananuj@gmail.com" method="POST">
                <!-- FormSubmit Configuration -->
                <input type="hidden" name="_subject" value="New Inquiry from Aaryan Anuj Enterprises Website">
                <input type="hidden" name="_captcha" value="false">
                <input type="hidden" name="_template" value="table">
                <input type="hidden" name="_next" value="https://yourdomain.com/thank-you.html">
                
                <div class="form-group">
                    <input type="text" name="name" placeholder="Your Name" required>
                    <i class="fas fa-user"></i>
                </div>
                <div class="form-group">
                    <input type="email" name="email" placeholder="Your Email" required>
                    <i class="fas fa-envelope"></i>
                </div>
                <div class="form-group">
                    <input type="tel" name="phone" placeholder="Phone Number" required>
                    <i class="fas fa-phone"></i>
                </div>
                <div class="form-group">
                    <input type="text" name="work_profile" placeholder="Work Profile / Occupation" required>
                    <i class="fas fa-briefcase"></i>
                </div>
                <div class="form-group">
                    <select name="interest" required>
                        <option value="">Select Interest</option>
                        <option value="Residential Property">Residential Property</option>
                        <option value="Commercial Property">Commercial Property</option>
                        <option value="Investment Inquiry">Investment Inquiry</option>
                        <option value="Other">Other</option>
                    </select>
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="form-group">
                    <textarea name="message" placeholder="Your Message" rows="5" required></textarea>
                    <i class="fas fa-comment"></i>
                </div>
                <button type="submit">Send Message <i class="fas fa-paper-plane"></i></button>
            </form>
        </div>
    </section>

